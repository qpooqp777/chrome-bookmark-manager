{
  "manifest_version": 3,
  "name": "書籤管理助手",
  "version": "1.0.4",
  "description": "快速搜尋、批次管理 Chrome 書籤",
  "permissions": [
    "bookmarks"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons8-bookmark-64.png",
      "48": "icons8-bookmark-64.png",
      "128": "icons8-bookmark-64.png"
    }
  },
  "icons": {
    "16": "icons8-bookmark-64.png",
    "48": "icons8-bookmark-64.png",
    "128": "icons8-bookmark-64.png"
  }
}
